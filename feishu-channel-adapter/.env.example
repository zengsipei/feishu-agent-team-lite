SERVICE_NAME=feishu-channel-adapter
ENVIRONMENT=production
LOG_LEVEL=WARNING

# HTTP address of feishu-agent-runtime.
RUNTIME_BASE_URL=http://feishu-agent-runtime:8080
RUNTIME_AUTH_TOKEN=change-me
RUNTIME_TIMEOUT_SECONDS=120

# Shared config generated by .agents/teams/code-rd-agent-team/build-runtime-config.py.
AGENT_RUNTIME_CONFIG_PATH=/app/config/agent-runtime-config.json
ADAPTER_STATUS_DIR=../.local-run/adapter-status

# Channel SDK settings.
CHANNEL_TRANSPORT=ws
CHANNEL_CONNECT_TIMEOUT_SECONDS=30
CHANNEL_REQUIRE_MENTION=true
CHANNEL_RESPOND_TO_MENTION_ALL=false
CHANNEL_DROP_SELF_SENT=true

# Optional comma-separated filters. Leave empty to enable every app in config.
ENABLED_APP_IDS=
ENABLED_AGENT_IDS=

# Optional Drive comment enrichment. Requires extra Drive comment scopes.
COMMENT_FETCH_ENABLED=false
COMMENT_REPLY_ENABLED=false
